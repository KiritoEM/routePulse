<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Code de vérification</title>
  <style>
    @import url('https://fonts.cdnfonts.com/css/general-sans');
    * {
      font-family: 'General Sans', 'Trebuchet MS', 'Segoe UI', Arial, sans-serif !important;
      font-weight: 400;
    }
    body {
      margin: 0;
      padding: 0;
      background-color: #F7F7F2;
    }
    .wrapper {
      background-color: #F7F7F2;
      min-height: 100vh;
      width: 100%;
    }
    .wrapper-td {
      min-height: 100vh;
    }
    .card {
      background-color: #ffffff;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
      margin: 0 auto;
      padding: 8px;
    }
    .card-td {
      padding: 28px;
      text-align: center;
    }
    .logo {
      width: 155px;
      object-fit: contain;
    }
    .logo {
      margin-bottom: 24px;
    }
    .title {
      font-size: 24px;
      margin-top: 0;
      line-height: 120%;
      margin-bottom: 16px;
      color: #2C2321;
      font-weight: 500;
    }
    .subtitle {
      color: #AEA198;
      font-size: 14px;
      margin-top: 0;
      margin-bottom: 16px;
    }
    .subtitle .name {
      font-weight: 600;
      color: #1E1E1E;
    }
    .code {
      font-size: 26px;
      letter-spacing: 10px;
      padding: 15px 30px;
      border-radius: 12px;
      background: rgba(255, 241, 213, 1);
      display: inline-block;
      margin-top: 0;
      margin-bottom: 16px;
      color: #1E1E1E;
      font-weight: 600;
    }
    .expiry {
      font-size: 13px;
      color: #1E1E1E;
      margin-top: 0;
      margin-bottom: 24px;
    }
    .expiry span {
      color: #5DA1FD;
      font-weight: 600;
    }
    .disclaimer {
      font-size: 12px;
      color: #AEA198;
      margin-top: 34px;
      margin-bottom: 0;
    }
  </style>
</head>
<body>
  <table class="wrapper" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
      <td class="wrapper-td" align="center" valign="middle">
        <table class="card" width="445" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td class="card-td">
              <img src="cid:logo@routepulse" alt="Logo" class="logo">
              <h1 class="title">Votre code de <br/> vérification</h1>
              <p class="subtitle">
                Bonjour <span class="name">{{name}}</span>, entrez ce code pour activer votre compte: 
              </p>
              <div class="code">{{otpCode}}</div>
              <p class="expiry">
                Ce code expire dans <span>{{expirationMinutes}} minutes</span>
              </p>
              <p class="disclaimer">Si vous n'avez pas demandé ce code, ignorez simplement cet email.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
